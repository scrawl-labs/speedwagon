# --- For @scrawl-labs/speedwagon (audit, production-safe read-only) ---
# Strongly recommended: a read-only user + secondary read preference.
# This minimizes risk to your primary even though the package is read-only.
MONGODB_URI=mongodb+srv://readonly_user:password@cluster.xxxxx.mongodb.net/?readPreference=secondaryPreferred&retryWrites=false
MONGODB_DATABASE=your_database_name

# --- For @scrawl-labs/speedwagon-lab (local mongod only) ---
# The lab package refuses non-local hosts at startup.
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DATABASE=speedwagon_lab
