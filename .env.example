# --- @scrawl-labs/speedwagon-mongodb (audit, production-safe read-only) ---
# Strongly recommended: a read-only user + secondary read preference.
# This minimizes risk to your primary even though the package is read-only.
MONGODB_URI=mongodb+srv://readonly_user:password@cluster.xxxxx.mongodb.net/?readPreference=secondaryPreferred&retryWrites=false
MONGODB_DATABASE=your_database_name

# --- @scrawl-labs/speedwagon-grafana (proxies the official mcp-grafana, read-only) ---
# Create a Grafana service account token with Viewer role.
GRAFANA_URL=https://your-stack.grafana.net
GRAFANA_SERVICE_ACCOUNT_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxx
# Optional: override how the upstream mcp-grafana binary is launched.
# Defaults to: uvx mcp-grafana -t stdio --disable-write
# GRAFANA_MCP_COMMAND=mcp-grafana
# GRAFANA_MCP_ARGS=-t stdio --disable-write

# --- @scrawl-labs/speedwagon-elastic (proxies Kibana Agent Builder MCP) ---
# API key needs the Kibana privilege feature_agentBuilder.read.
KIBANA_URL=https://your-deployment.kb.cloud.es.io
ELASTIC_API_KEY=your_base64_encoded_api_key
# Optional: target a non-default Kibana space.
# KIBANA_SPACE=my-space
