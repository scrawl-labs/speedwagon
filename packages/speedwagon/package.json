{
  "name": "@scrawl-labs/speedwagon",
  "version": "0.1.0",
  "description": "Shared MCP server infrastructure for the Speedwagon family (MongoDB, Elastic, Grafana). Provides runMcpServer, defineTool, and env helpers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -b",
    "pretest": "tsc -b",
    "test": "node --test",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.23"
  },
  "keywords": ["mcp", "speedwagon", "shared", "infrastructure"],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
