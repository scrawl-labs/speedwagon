{
  "uid": "speedwagon-dev",
  "title": "Speedwagon Dev Sample",
  "tags": ["speedwagon", "dev"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Prometheus HTTP request rate",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(prometheus_http_requests_total[1m])",
          "legendFormat": "{{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Container logs",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{container=~\".+\"}"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": false
      }
    }
  ]
}
